# Server Configuration
NODE_ENV=development
PORT=8080
WS_PORT=8081
HOST=0.0.0.0

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_KEY=your-api-key-for-basic-auth

# Redis Configuration (for Pub/Sub and clustering)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS Configuration (alternative to Redis)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# Inference Configuration
INFERENCE_ENABLED=true
INFERENCE_MODE=rest
INFERENCE_REST_URL=http://localhost:5000/inference
INFERENCE_GRPC_HOST=localhost
INFERENCE_GRPC_PORT=50051
INFERENCE_WS_URL=ws://localhost:5001
INFERENCE_TIMEOUT=30000
INFERENCE_RETRY_ATTEMPTS=3
INFERENCE_RETRY_DELAY=1000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Clustering
CLUSTER_ENABLED=false
CLUSTER_WORKERS=4

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Heartbeat
HEARTBEAT_INTERVAL=30000
CLIENT_TIMEOUT=60000
