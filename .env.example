# Server Configuration
NODE_ENV=production
PORT=8080
WS_PORT=8080
HOST=0.0.0.0

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_KEY=your-api-key-for-service-to-service-auth

# Redis Configuration (for Pub/Sub scaling)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS Configuration (alternative to Redis)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# Inference Bridge Configuration
INFERENCE_ENABLED=true
INFERENCE_ENDPOINT=http://localhost:5000/inference
INFERENCE_TIMEOUT=30000
INFERENCE_RETRIES=3

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Security
CORS_ORIGIN=*
MAX_CONNECTIONS_PER_IP=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Clustering
CLUSTER_ENABLED=false
CLUSTER_WORKERS=4
