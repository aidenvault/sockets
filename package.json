{
  "name": "websocket-api-server",
  "version": "1.0.0",
  "description": "Production-ready WebSocket API server for real-time messaging, streaming, and inference orchestration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs websocket-api-server"
  },
  "keywords": [
    "websocket",
    "api",
    "real-time",
    "inference",
    "messaging",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.16.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "nats": "^2.19.0",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
