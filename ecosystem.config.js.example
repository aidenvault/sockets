/**
 * PM2 Ecosystem Configuration
 * 
 * This file configures PM2 for running the WebSocket API server.
 * Copy this file to ecosystem.config.js and customize as needed.
 * 
 * Usage:
 *   pm2 start ecosystem.config.js
 *   pm2 reload ecosystem.config.js --update-env
 *   pm2 stop ecosystem.config.js
 */

module.exports = {
  apps: [{
    // Application name
    name: 'websocket-api-server',
    
    // Entry point
    script: './src/server.js',
    
    // Instance configuration
    instances: process.env.CLUSTER_ENABLED === 'true' 
      ? (parseInt(process.env.CLUSTER_WORKERS, 10) || 'max')
      : 1,
    
    // Execution mode: 'fork' or 'cluster'
    exec_mode: process.env.CLUSTER_ENABLED === 'true' ? 'cluster' : 'fork',
    
    // Auto-restart on crash
    autorestart: true,
    
    // Watch for file changes (disable in production)
    watch: false,
    
    // Max memory before restart
    max_memory_restart: '1G',
    
    // Environment variables
    env: {
      NODE_ENV: 'production',
    },
    
    // Development environment
    env_development: {
      NODE_ENV: 'development',
      LOG_LEVEL: 'debug',
    },
    
    // Production environment
    env_production: {
      NODE_ENV: 'production',
      LOG_LEVEL: 'info',
    },
    
    // Logging
    error_file: './logs/pm2-error.log',
    out_file: './logs/pm2-out.log',
    log_file: './logs/pm2-combined.log',
    time: true,
    merge_logs: true,
    log_date_format: 'YYYY-MM-DD HH:mm:ss Z',
    
    // Process management
    kill_timeout: 5000,
    listen_timeout: 3000,
    shutdown_with_message: true,
    
    // Graceful shutdown
    kill_retry_time: 100,
    
    // CPU and memory monitoring
    min_uptime: '10s',
    max_restarts: 10,
    
    // Additional options
    node_args: '--max-old-space-size=4096',
    
    // Post-deploy hooks (optional)
    // post_update: ['npm install', 'echo Deployment complete'],
  }],
  
  // Deployment configuration (optional)
  deploy: {
    production: {
      user: 'deployuser',
      host: 'your-server.com',
      ref: 'origin/main',
      repo: 'git@github.com:yourusername/websocket-api-server.git',
      path: '/opt/websocket-api-server',
      'post-deploy': 'npm install && pm2 reload ecosystem.config.js --env production',
      'pre-deploy-local': '',
      'post-deploy-local': '',
    },
    
    staging: {
      user: 'deployuser',
      host: 'staging-server.com',
      ref: 'origin/develop',
      repo: 'git@github.com:yourusername/websocket-api-server.git',
      path: '/opt/websocket-api-server-staging',
      'post-deploy': 'npm install && pm2 reload ecosystem.config.js --env development',
    }
  }
};
